
GRAPHRAG_API_KEY=__FILL_YOUR_DEEPSEEK_API_KEY__

GRAPHRAG_API_KEY_EMBEDDING=__FILL_YOUR_SILICONFLOW_API_KEY__


GRAPHRAG_LLM_MODEL=deepseek-chat

GRAPHRAG_EMBEDDING_MODEL=BAAI/bge-m3

API_BASE=https://api.deepseek.com/v1

API_BASE_EMBEDDING=https://api.siliconflow.cn/v1

PORT=8012

# 服务绑定地址（Docker 中通常设为 0.0.0.0）
BIND_HOST=127.0.0.1

# 浏览器跨域来源，逗号分隔
CORS_ALLOW_ORIGINS=http://localhost:8012,http://127.0.0.1:8012
